---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Nav from '../../components/Nav.astro';
import Footer from '../../components/Footer.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const posts = await getCollection('newsletter');
  return posts.map(post => ({
    params: { id: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);
---

<BaseLayout title={`${post.data.title} — Causalera`}>
  <Nav />
  <article class="post-page">
    <header class="post-header">
      <a href="/newsletter" class="back-link">← All issues</a>
      <time datetime={post.data.date.toISOString()}>
        {post.data.date.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}
      </time>
      <h1>{post.data.title}</h1>
      <p class="post-description">{post.data.description}</p>
    </header>
    <div class="post-content">
      <Content />
    </div>
    <footer class="post-footer">
      <a href="/newsletter" class="back-link">← Back to all issues</a>
    </footer>
  </article>
  <Footer />
</BaseLayout>

<style>
  .post-page{
    max-width:680px;margin:0 auto;
    padding:140px 32px 88px;
  }
  .back-link{
    font-family:'DM Sans',sans-serif;font-size:15px;font-weight:600;
    color:var(--primary);text-decoration:none;
    transition:color 0.2s;
  }
  .back-link:hover{color:var(--accent)}
  .post-header{
    margin-bottom:48px;
  }
  .post-header time{
    display:block;
    font-family:'DM Sans',sans-serif;font-size:14px;font-weight:600;
    letter-spacing:0.5px;text-transform:uppercase;
    color:var(--accent);
    margin-top:24px;
  }
  .post-header h1{
    font-family:'DM Sans',sans-serif;font-weight:700;
    font-size:36px;line-height:1.15;
    color:var(--text);
    margin:16px 0 12px;
  }
  .post-description{
    font-size:17px;line-height:1.6;
    color:var(--text-secondary);
    font-style:italic;
  }
  .post-content{
    font-size:17px;line-height:1.8;
    color:var(--text);
  }
  .post-content :global(h2){
    font-family:'DM Sans',sans-serif;font-weight:700;
    font-size:24px;line-height:1.3;
    color:var(--text);
    margin:40px 0 16px;
  }
  .post-content :global(p){
    margin-bottom:20px;
    color:var(--text-secondary);
  }
  .post-content :global(strong){
    color:var(--text);
  }
  .post-content :global(em){
    font-style:italic;
  }
  .post-content :global(ul),
  .post-content :global(ol){
    margin:0 0 20px 24px;
    color:var(--text-secondary);
  }
  .post-content :global(li){
    margin-bottom:8px;
  }
  .post-content :global(li strong){
    color:var(--text);
  }
  .post-footer{
    margin-top:64px;
    padding-top:32px;
    border-top:1px solid var(--border);
  }

  @media(max-width:768px){
    .post-header h1{font-size:28px}
  }
</style>
